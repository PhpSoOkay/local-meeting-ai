# API-ключи для AI-моделей Meeting AI
# Раскомментируйте нужные строки и укажите свои ключи

# RouterAI (рекомендуется — единый ключ для GPT-4o, Claude, MAI-Transcribe)
# ROUTERAI_API_KEY=sk-...

# OpenAI напрямую
# OPENAI_API_KEY=sk-...

# OpenRouter
# OPENROUTER_API_KEY=sk-or-...

# Anthropic напрямую
# ANTHROPIC_API_KEY=sk-ant-...
